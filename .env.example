# netmon server — konfigurace prostředí (Coolify env vars nebo server/.env).
#
# Bez vyplněného SMTP_HOST + SMTP_TO se denní e-mailové reporty neposílají
# (vše ostatní funguje normálně — data jsou na webu).

# --- Evaluation server ---
# Cesta k SQLite databázi (v Dockeru nech /data/netmon.db — je na volume)
NETMON_DB=/data/netmon.db
# Cesta k seznamu monitorů (viz server/config/monitors.toml.example)
NETMON_MONITORS=/data/monitors.toml
# Časová zóna reportů a denních rozsahů
NETMON_TZ=Europe/Prague
# Hodina, kdy se posílá denní report (za předchozí den)
NETMON_REPORT_HOUR=3

# --- SMTP pro denní reporty ---
# SMTP server (povinné pro odeslání)
SMTP_HOST=smtp.gmail.com
# Port — nepovinné, podle SMTP_TLS se doplní výchozí: starttls→587, ssl→465, none→25
SMTP_PORT=587
# Šifrování: starttls (výchozí) | ssl | none
SMTP_TLS=starttls
# Přihlášení (nepovinné — když ho server nevyžaduje, nech prázdné)
SMTP_USER=tvuj@gmail.com
SMTP_PASS=heslo-nebo-app-password
# Odesílatel (nepovinné, výchozí = SMTP_USER)
SMTP_FROM=tvuj@gmail.com
# Příjemce/příjemci reportu (povinné pro odeslání) — víc oddělíš čárkou
SMTP_TO=ja@example.com
# SMTP_DRYRUN=1 → e-mail se neodešle, uloží se jako .eml (testování)
