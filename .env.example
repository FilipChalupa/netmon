# netmon server — environment configuration (Coolify env vars or server/.env).
#
# Without SMTP_HOST + SMTP_TO filled in, daily email reports are not sent
# (everything else works normally — the data is on the web).

# --- Evaluation server ---
# Path to the SQLite database (in Docker keep /data/netmon.db — it's on the volume)
NETMON_DB=/data/netmon.db
# Path to the monitor list (see server/config/monitors.toml.example)
NETMON_MONITORS=/data/monitors.toml
# Time zone for reports and daily ranges
NETMON_TZ=Europe/Prague
# Hour at which the daily report (for the previous day) is sent
NETMON_REPORT_HOUR=3

# --- Alerting (emails as things happen; needs SMTP_* below) ---
# Disable with 0
NETMON_ALERTS=1
# Alert on outages at least this long (seconds)
NETMON_ALERT_MIN_OUTAGE_S=60
# Alert when a monitor hasn't synced for this long (seconds)
NETMON_ALERT_OFFLINE_S=600

# --- SMTP for daily reports ---
# SMTP server (required for sending)
SMTP_HOST=smtp.gmail.com
# Port — optional, default depends on SMTP_TLS: starttls→587, ssl→465, none→25
SMTP_PORT=587
# Encryption: starttls (default) | ssl | none
SMTP_TLS=starttls
# Login (optional — leave empty when the server doesn't require it)
SMTP_USER=you@gmail.com
SMTP_PASS=password-or-app-password
# Sender (optional, default = SMTP_USER)
SMTP_FROM=you@gmail.com
# Report recipient(s) (required for sending) — separate multiple with commas
SMTP_TO=me@example.com
# SMTP_DRYRUN=1 → the email is not sent, it is saved as .eml (testing)
