# netmon — konfigurace odesílání reportů e-mailem.
# Zkopíruj na .env (`cp .env.example .env`) a vyplň. Soubor .env je v .gitignore.
#
# Když .env neexistuje nebo nemá vyplněný SMTP_HOST + SMTP_TO, report-daily.sh
# report jen vygeneruje na disk a e-mail neposílá.

# SMTP server (povinné pro odeslání)
SMTP_HOST=smtp.gmail.com

# Port — nepovinné, podle SMTP_TLS se doplní výchozí:
#   starttls → 587, ssl → 465, none → 25
SMTP_PORT=587

# Šifrování: starttls (výchozí) | ssl | none
SMTP_TLS=starttls

# Přihlášení (nepovinné — když je server nevyžaduje, nech prázdné)
SMTP_USER=tvuj@gmail.com
SMTP_PASS=heslo-nebo-app-password

# Odesílatel (nepovinné, výchozí = SMTP_USER)
SMTP_FROM=tvuj@gmail.com

# Příjemce/příjemci reportu (povinné pro odeslání) — víc oddělíš čárkou
SMTP_TO=ja@example.com
