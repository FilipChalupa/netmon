# netmon monitor — agent configuration
# Copy to ~/.config/netmon/monitor.ini and edit.

[monitor]
# Network name — must match the entry in monitors.toml on the evaluation server.
network = home
# Port of the mini HTTP API (the evaluation server reads it over Tailscale).
port = 8787
# Address to listen on. 0.0.0.0 = everywhere; narrow to the Tailscale IP (100.x.y.z) if you like.
bind = 0.0.0.0
# Shared token (X-Netmon-Token header). Empty = no check.
token =
# Where to store the local SQLite measurement database.
db_path = ~/.local/share/netmon/monitor.db
# How long to keep local data (the evaluation server pulls it continuously).
retention_days = 90

[probes]
# Seconds between ping rounds / waiting for a reply.
ping_interval = 2
ping_timeout = 2
# Ping targets: name=IP; gateway = auto (detected from the default route).
targets = gateway=auto, quad9=9.9.9.9, google=8.8.8.8
# Reach probe (DNS/TCP/TLS) — interval and target.
reach_interval = 30
reach_url = https://www.google.com/generate_204
# Speed test — interval (3600 = hourly), size (50 MB ≈ 1.2 GB/day).
speed_interval = 3600
speed_bytes = 50000000
speed_url = https://speed.cloudflare.com/__down?bytes={bytes}
# Fast lines: a test finishing under speed_min_seconds is re-measured once
# with a larger payload (sized for ~2× that duration, capped at speed_max_bytes).
speed_min_seconds = 3
speed_max_bytes = 200000000
# Heartbeat into the uptime log (detects when measuring wasn't running).
heartbeat_interval = 60
