# netmon server — list of monitors to pull data from.
# Copy as monitors.toml (in Docker: /data/monitors.toml).

# How often to pull new data (seconds).
sync_interval = 30

[[monitors]]
name = "home"                     # must match 'network' in monitor.ini
label = "Home"
url = "http://100.64.0.1:8787"    # Tailscale IP or MagicDNS name of the monitor
token = "secret-token"            # same as 'token' in monitor.ini

[[monitors]]
name = "cottage"
label = "Cottage"
url = "http://100.64.0.2:8787"
token = "secret-token"
