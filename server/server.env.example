# netmon evaluation server — environment for the systemd install
# (installed as /etc/netmon/server.env; for Docker/Coolify see ../.env.example)

NETMON_DB=/var/lib/netmon-server/netmon.db
NETMON_MONITORS=/etc/netmon/monitors.toml
NETMON_TZ=Europe/Prague
NETMON_REPORT_HOUR=3

# --- Alerting (emails as things happen; needs SMTP_* below) ---
NETMON_ALERTS=1
NETMON_ALERT_MIN_OUTAGE_S=60
NETMON_ALERT_OFFLINE_S=600
NETMON_ALERT_SPEED_PCT=50

# --- SMTP for daily reports and alerts (empty = nothing is sent) ---
SMTP_HOST=
SMTP_TO=
SMTP_TLS=starttls
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
